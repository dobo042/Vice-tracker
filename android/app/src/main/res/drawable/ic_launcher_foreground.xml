<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — geometric beer mug badge.
  White ring (r=46) over olive tan circle (r=42) over dark-olive background.
  Mug: solid dark rectangle body + thick D-arc handle on the right.
  All coordinates in 108dp viewport; safe zone 18–90.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- White ring border -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 54,54 m -46,0 a 46,46 0 1,0 92,0 a 46,46 0 1,0 -92,0"/>

    <!-- Warm olive tan circle fill -->
    <path
        android:fillColor="#7A6E2D"
        android:pathData="M 54,54 m -42,0 a 42,42 0 1,0 84,0 a 42,42 0 1,0 -84,0"/>

    <!-- Mug body (solid rectangle) -->
    <path
        android:fillColor="#3A2605"
        android:pathData="M 28,28 L 60,28 L 60,76 L 28,76 Z"/>

    <!-- Mug handle: smooth D-arc, stroke only (creates finger-hole opening) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#3A2605"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:pathData="M 60,36 C 90,36 90,68 60,68"/>

</vector>
